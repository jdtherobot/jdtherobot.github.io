{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "components/surface/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Rajdhani|Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Rajdhani, Space Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|href|children|onClick|disabled|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, href, children, onClick, disabled, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tier|stencil|children|style|innerStyle|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tier, stencil, children, style, innerStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:plain|branch|dissolve)$/]",
        "message": "<Card> tier must be one of 'plain' | 'branch' | 'dissolve'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|on|as|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, on, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='on'] > Literal[value!=/^(?:bg|panel)$/]",
        "message": "<Eyebrow> on must be one of 'bg' | 'panel'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Figure'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|caption|ratio|children|style|imgStyle|key|ref|className|style|children)$/]",
        "message": "<Figure> doesn't accept that prop. Declared props: src, alt, caption, ratio, children, style, imgStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModeToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:showLabel|style|key|ref|className|style|children)$/]",
        "message": "<ModeToggle> doesn't accept that prop. Declared props: showLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|title|href|date|style|key|ref|className|style|children)$/]",
        "message": "<NoteRow> doesn't accept that prop. Declared props: tag, title, href, date, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|on|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, on, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='on'] > Literal[value!=/^(?:bg|panel)$/]",
        "message": "<Tag> on must be one of 'bg' | 'panel'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TierLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|style|key|ref|className|style|children)$/]",
        "message": "<TierLine> doesn't accept that prop. Declared props: variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TierLine'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|branch|dissolve)$/]",
        "message": "<TierLine> variant must be one of 'plain' | 'branch' | 'dissolve'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaveTrace'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|width|strokeWidth|title|style|key|ref|className|style|children)$/]",
        "message": "<WaveTrace> doesn't accept that prop. Declared props: color, width, strokeWidth, title, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
